{
  "entities": {
    "ContactMessage": {
      "title": "Contact Message",
      "description": "Messages sent through the contact form",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Sender's name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Sender's email"
        },
        "message": {
          "type": "string",
          "description": "Message content"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Server-side timestamp"
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "messages/{messageId}": {
      "schema": "ContactMessage",
      "description": "Collection of contact form submissions"
    }
  }
}
