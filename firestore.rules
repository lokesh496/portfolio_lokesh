rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() >= 2 && data.name.size() <= 100 &&
             data.email is string && data.email.size() >= 5 && data.email.size() <= 100 &&
             data.message is string && data.message.size() >= 1 && data.message.size() <= 5000 &&
             data.createdAt == request.time;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Contact messages
    match /messages/{messageId} {
      allow create: if isValidId(messageId) && isValidMessage(incoming());
      allow read, update, delete: if false;
    }
  }
}
